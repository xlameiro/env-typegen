{
  "inputs": [
    {
      "id": "CONTEXT7_API_KEY",
      "type": "promptString",
      "description": "API key for authentication",
      "password": true
    },
    {
      "id": "Authorization",
      "type": "promptString",
      "description": "GitHub PAT — required scopes: repo (read/write), read:org, issues (read/write), pull_requests (read/write). Format: Bearer ghp_...",
      "password": true
    }
  ],
  "servers": {
    "io.github.upstash/context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn", "mcp"],
      "type": "stdio"
    },
    "microsoft/playwright-mcp": {
      "command": "npx",
      "args": ["-y", "mcp-server-playwright"],
      "type": "stdio"
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp"],
      "type": "stdio"
    },
    "io.github.github/github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "${input:Authorization}"
      }
    }
  }
}
