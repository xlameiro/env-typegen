# ============================================================
# App
# ============================================================
# For OAuth callbacks, use a stable URL. Two options:
#   1. Standard dev:   NEXT_PUBLIC_APP_URL=http://localhost:3000
#   2. Portless HTTPS: run 'pnpm dev:local:https' and set the domain
#      Portless generates: https://<package-name>.localhost
#      e.g.             NEXT_PUBLIC_APP_URL=https://nextjs16-starter-template.localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# Auth.js v5 (NextAuth)
# Generate a secret: openssl rand -base64 32
# ============================================================
AUTH_SECRET=your-auth-secret-here

# ============================================================
# OAuth Providers — uncomment the ones you use
# ============================================================
#
# Google OAuth — https://console.cloud.google.com/
# Authorized redirect URI to add in Google Cloud Console:
#   - Standard:      http://localhost:3000/api/auth/callback/google
#   - Portless HTTPS: https://nextjs16-starter-template.localhost/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# ============================================================
# Database (uncomment when adding a DB adapter)
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
