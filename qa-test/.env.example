# QA Test — .env.example
# Tests: basic key=value, empty values, comments, type inference

# --- Database ---

# @description PostgreSQL main database connection string
# @required
DATABASE_URL=postgresql://localhost:5432/qa_db

# @description Read replica (optional)
DATABASE_READONLY_URL=

# @description Max pool connections
DATABASE_POOL_SIZE=10

# --- Server ---

# @required
PORT=3000
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# --- Auth ---

# @description JWT signing secret (>=32 chars)
# @required
# @type string
AUTH_SECRET=

# @description Token expiry in seconds
AUTH_TOKEN_EXPIRY=3600

# --- External APIs ---

# @description Stripe secret key
# @required
STRIPE_SECRET_KEY=

# @description Webhook signing secret
STRIPE_WEBHOOK_SECRET=

# --- Public vars (NEXT_PUBLIC_*) ---

# @required
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_FEATURE_FLAGS={"darkMode":true,"newCheckout":false}

# --- Feature Flags ---

ENABLE_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false
ENABLE_BETA_FEATURES=false

# --- Misc ---

APP_VERSION=1.0.0
ALLOWED_ORIGINS=https://example.com,https://www.example.com
MAX_UPLOAD_SIZE=5242880
