# QA dummy fixture — cubre todos los tipos inferibles por env-typegen 0.1.8
# Contiene: string, number, boolean, url, email, opcional, anotaciones @type

# --- Database ---
# @description Main PostgreSQL connection string
# @required
DATABASE_URL=postgresql://localhost:5432/qa_db

# @description Read replica URL (optional)
DATABASE_READONLY_URL=

# --- Server ---
PORT=3000
MAX_CONNECTIONS=10
DEBUG=false
NODE_ENV=development

# --- Auth ---
# @description Application secret — must be at least 32 chars
# @required
AUTH_SECRET=

# @description JWT secret (alias)
JWT_SECRET=

# --- External services ---
API_BASE_URL=https://api.example.com
WEBHOOK_URL=https://hooks.example.com/abc123
SMTP_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# --- Feature flags ---
ENABLE_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false

# --- App metadata ---
APP_VERSION=1.0.0
APP_NAME=qa-app

# --- NEXT_PUBLIC_ client vars ---
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_FEATURE_FLAGS={"analytics":true}
