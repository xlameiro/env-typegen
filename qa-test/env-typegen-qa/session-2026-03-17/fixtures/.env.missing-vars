# Purposefully missing WEBHOOK_URL (required) and ENABLE_ANALYTICS, APP_VERSION
# Also has an extra UNKNOWN_VAR not in the contract → ENV_EXTRA error in strict mode
DATABASE_URL=postgresql://localhost:5432/mydb
PORT=3000
MAX_CONNECTIONS=10
DEBUG=false
NODE_ENV=development
AUTH_SECRET=my-super-secret-value-at-least-32-chars-long
API_BASE_URL=https://api.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
ENABLE_MAINTENANCE_MODE=false
APP_NAME=qa-app
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_FEATURE_FLAGS={"analytics":false}
UNKNOWN_VAR=some_value
