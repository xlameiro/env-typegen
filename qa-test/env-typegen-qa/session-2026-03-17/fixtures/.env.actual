# Full .env satisfying all variables in fixtures/.env.example
DATABASE_URL=postgresql://localhost:5432/mydb
DATABASE_READONLY_URL=postgresql://localhost:5432/mydb
PORT=3000
MAX_CONNECTIONS=10
DEBUG=false
NODE_ENV=production
AUTH_SECRET=my-super-secret-value-at-least-32-chars-long
JWT_SECRET=another-jwt-secret-value
API_BASE_URL=https://api.example.com
WEBHOOK_URL=https://hooks.example.com/incoming
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
ENABLE_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false
APP_VERSION=1.0.0
APP_NAME=qa-app
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_FEATURE_FLAGS={"analytics":true}
