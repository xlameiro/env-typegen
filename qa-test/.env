# Real environment — fully valid, matches contract
DATABASE_URL=postgresql://prod-host:5432/prod_db
DATABASE_READONLY_URL=postgresql://readonly-host:5432/prod_db
DATABASE_POOL_SIZE=20

PORT=8080
NODE_ENV=production
DEBUG=false
LOG_LEVEL=warn

AUTH_SECRET=super-secret-signing-key-at-least-32-chars-long!!
AUTH_TOKEN_EXPIRY=7200

STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_NOT_REAL
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_NOT_REAL

NEXT_PUBLIC_APP_URL=https://myapp.com
NEXT_PUBLIC_API_URL=https://api.myapp.com
NEXT_PUBLIC_ANALYTICS_ID=UA-12345678-1
NEXT_PUBLIC_FEATURE_FLAGS={"darkMode":true,"newCheckout":true}

ENABLE_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false
ENABLE_BETA_FEATURES=false

APP_VERSION=2.1.0
ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
MAX_UPLOAD_SIZE=10485760
