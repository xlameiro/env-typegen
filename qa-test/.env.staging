# Staging environment — has drift: missing some vars, extra undeclared vars
DATABASE_URL=postgresql://staging-host:5432/staging_db
DATABASE_POOL_SIZE=5

PORT=3000
NODE_ENV=staging
DEBUG=true
LOG_LEVEL=debug

AUTH_SECRET=staging-secret-key-at-least-32-chars-long!!
AUTH_TOKEN_EXPIRY=3600

# Missing: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET

NEXT_PUBLIC_APP_URL=https://staging.myapp.com
NEXT_PUBLIC_API_URL=https://api.staging.myapp.com
# Missing: NEXT_PUBLIC_ANALYTICS_ID, NEXT_PUBLIC_FEATURE_FLAGS

ENABLE_ANALYTICS=false
ENABLE_MAINTENANCE_MODE=false
# Missing: ENABLE_BETA_FEATURES

APP_VERSION=2.1.0
# Missing: ALLOWED_ORIGINS, MAX_UPLOAD_SIZE

# Extra undeclared vars (should trigger strict warning/error)
SENTRY_DSN=https://staging.sentry.io/12345
NEW_RELIC_LICENSE_KEY=staging-license-key
