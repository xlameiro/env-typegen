# Next.js .env.example fixture
# Tests the NEXT_PUBLIC_ prefix detection (client vs server split).

# Server-side vars — must never be exposed to the browser
DATABASE_URL=postgresql://localhost:5432/mydb
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Client-side vars — safe for browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX
