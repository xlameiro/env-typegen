# Basic .env.example fixture
# Tests the parser's core functionality: simple key=value pairs,
# required vs optional variables, and type inference from values.

# Database
DATABASE_URL=postgresql://localhost:5432/mydb

# Server
PORT=3000
DEBUG=false
NODE_ENV=development

# Authentication — empty value means optional
AUTH_SECRET=

# External services
WEBHOOK_URL=https://hooks.example.com/abc123
