# Complex .env.example fixture
# Tests JSDoc annotations (@description, @required, @type),
# semantic section headers, and edge cases.

# --- Database ---

# @description PostgreSQL connection string for the main database
# @required
DATABASE_URL=postgresql://localhost:5432/mydb

# @description Read-only replica URL for analytics queries
DATABASE_READONLY_URL=

# @description Redis connection string for caching
REDIS_URL=redis://localhost:6379

# --- Auth ---

# @description Auth.js signing secret (>=32 chars)
# @required
# @type string
CRITICAL_API_KEY=

# @description Google OAuth client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Email ---
SMTP_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# --- Feature Flags ---
ENABLE_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false

# --- App ---
APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_FEATURE_FLAGS={"analytics":true}
