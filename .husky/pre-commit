#!/usr/bin/env sh
# Husky pre-commit hook
# Runs lint-staged (ESLint + Prettier) on staged files only.
# Full quality gate (type-check + tests + build) runs in CI.

set -e

echo "🔐 Scanning staged changes for secrets..."
sh .github/hooks/scripts/git-secret-scan.sh

echo "🔍 Running lint-staged on staged files..."
pnpm exec lint-staged

echo "🔷 Running TypeScript type check..."
pnpm type-check

echo "🔍 Checking for dead code..."
pnpm knip

echo "🔒 Running security audit..."
pnpm audit --audit-level=moderate

echo "✅ Pre-commit checks passed."
